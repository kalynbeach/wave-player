{
  "name": "wave-player",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run build:wave-player && next dev --turbopack",
    "build": "bun run build:wave-player && next build",
    "build:turbo": "bun run build:wave-player && next build --turbopack",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "build:worker": "bun run scripts/build-worker.ts",
    "build:worklet": "bun run scripts/build-worklet.ts",
    "build:wave-player": "bun run build:worker && bun run build:worklet"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "babel-plugin-react-compiler": "^19.1.0-rc.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.541.0",
    "meyda": "^5.6.3",
    "next": "15.5.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "tonal": "^6.4.2",
    "tw-animate-css": "^1.3.7",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/audioworklet": "^0.0.82",
    "@types/bun": "^1.2.20",
    "@types/dom-webcodecs": "^0.1.16",
    "@types/meyda": "^5.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.34.0",
    "eslint-config-next": "15.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.12",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "prettier": {
    "semi": true,
    "tabWidth": 2,
    "singleQuote": false,
    "trailingComma": "es5",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  }
}
